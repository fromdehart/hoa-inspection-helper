# Environment for NATIVE (Capacitor) builds.
# These are baked into the bundle at build time by `npm run build:mobile`.
# Copy to `.env.mobile` (or `.env.production` used by the mobile build) and fill in.
#
# IMPORTANT: unlike the web app, a phone cannot reach your dev machine's localhost.
# Every URL below MUST be a real, publicly reachable https host.

# Convex deployment URL (same as web) — e.g. https://your-deployment.convex.cloud
VITE_CONVEX_URL=

# Clerk publishable key (same as web)
VITE_CLERK_PUBLISHABLE_KEY=

# Photo/doc upload server — MUST be the real https VPS, NOT http://localhost:3001
VITE_UPLOAD_SERVER_URL=https://uploads.happierblock.com

# Optional upload auth token (must match UPLOAD_TOKEN on the server)
VITE_UPLOAD_TOKEN=

# Optional analytics id
VITE_CHALLENGE_ID=
