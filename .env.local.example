# Frontend (VITE_ prefix — bundled into client JS)
VITE_CONVEX_URL=https://happy-animal-123.convex.cloud
VITE_UPLOAD_SERVER_URL=http://localhost:3001
# Production: HTTPS upload host (Caddy on VPS proxies to Node on :3001)
# VITE_UPLOAD_SERVER_URL=https://hoauploads.bigideer.com

# Optional: extra fields on [hoa-auth] console logs (vite mode, etc.)
# VITE_AUTH_DEBUG=1

# Convex server environment (set via: npx convex env set KEY value)
# OPENAI_API_KEY=sk-...
# RESEND_API_KEY=re_...
# RESEND_FROM=HOA Inspection <noreply@yourdomain.com>
# PUBLIC_BASE_URL=https://yourdomain.com

# VPS upload server (set in server process / systemd unit)
# PORT=3001
# BASE_URL=http://localhost:3001
# UPLOADS_DIR=/var/www/hoa-inspection-helper/uploads
# ALLOWED_ORIGIN=https://yourdomain.com
