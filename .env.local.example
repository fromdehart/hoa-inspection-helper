# Frontend (VITE_ prefix — bundled into client JS)
VITE_CONVEX_URL=https://happy-animal-123.convex.cloud
VITE_UPLOAD_SERVER_URL=http://localhost:3001
# Optional: same value as UPLOAD_DELETE_TOKEN on the upload server (removes stale letter PDFs on re-render)
# VITE_UPLOAD_DELETE_TOKEN=your-long-random-string
# Production: HTTPS upload host (Caddy on VPS proxies to Node on :3001)
# VITE_UPLOAD_SERVER_URL=https://hoauploads.bigideer.com

# Optional: extra fields on [hoa-auth] console logs (vite mode, etc.)
# VITE_AUTH_DEBUG=1

# Local-only: must match Convex `DEMO_SEED_SECRET` when running `npm run seed:demo`
# DEMO_SEED_SECRET=
#
# Platform super admin bootstrap (Convex env + local shell for `npm run seed:platform-admin`):
# npx convex env set PLATFORM_BOOTSTRAP_SECRET your-long-random-string
# PLATFORM_BOOTSTRAP_SECRET=
# Or run: npm run bootstrap:platform-admin

# Convex server environment (set via: npx convex env set KEY value)
# OPENAI_API_KEY=sk-...
# RESEND_API_KEY=re_...
# RESEND_FROM=Happier Block <noreply@happierblock.com>
# CLERK_SECRET_KEY=sk_live_...
#
# Production (https://happierblock.com): set homeowner/portal links and keep in sync with your live app URL.
# npx convex env set PUBLIC_BASE_URL "https://happierblock.com"
# PUBLIC_BASE_URL=https://happierblock.com
# Optional if referenced by your deployment:
# npx convex env set APP_BASE_URL "https://happierblock.com"
# Inspector photo delete (Convex action → VPS); same UPLOAD_DELETE_TOKEN as the upload Node process:
# npx convex env set UPLOAD_SERVER_URL https://hoauploads.bigideer.com
# npx convex env set UPLOAD_DELETE_TOKEN your-long-random-string

# VPS upload server (set in server process / systemd unit)
# PORT=3001
# BASE_URL=http://localhost:3001
# UPLOADS_DIR=/var/www/hoa-inspection-helper/uploads
# Production: allow the SPA origin (use apex or www consistently with Clerk).
# ALLOWED_ORIGIN=https://happierblock.com
# UPLOAD_DELETE_TOKEN=your-long-random-string

# VPS photo backup to Backblaze B2 (awesomework-vps only — not Convex/Vite)
# Copy scripts/b2.env.example → ~/.config/hoa-backup/b2.env on the VPS (chmod 600).
# Nightly cron: scripts/backup-photos-b2.sh (or npm run backup:photos on the VPS)
# B2_ACCOUNT_ID=...
# B2_APPLICATION_KEY=...
# B2_BUCKET=hoa-inspection-photos
# PHOTOS_SOURCE_DIR=/home/mike/hoa-inspection-upload-data
# B2_CONVEX_BUCKET=hoa-convex-backups  # separate bucket; see scripts/setup-b2-convex-interactive.sh
