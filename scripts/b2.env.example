# Copy to ~/.config/hoa-backup/b2.env on awesomework-vps (chmod 600).
# Never commit the real file.
#
# Easier: run interactive setup (prompts for keyID + secret on the VPS):
#   npm run setup:photos-backup
#   bash scripts/setup-b2-convex-interactive.sh   # Convex DB exports (separate bucket)
#
# --- Photos bucket ---
# Backblaze setup (one-time, web console):
#   1. Create private bucket: hoa-inspection-photos
#   2. Create Application Key scoped to that bucket (Read and Write)
#   3. B2 → Caps & Alerts: Storage $0.05/day, Downloads $0.01/day
#
# Then configure rclone on the VPS:
#   rclone config create hoa-b2 b2 account="$B2_ACCOUNT_ID" key="$B2_APPLICATION_KEY" hard_delete=false

B2_ACCOUNT_ID=
B2_APPLICATION_KEY=
B2_BUCKET=hoa-inspection-photos
PHOTOS_SOURCE_DIR=/home/mike/hoa-inspection-upload-data
RCLONE_REMOTE=hoa-b2

# Optional: abort backup if VPS photo folder exceeds this size (GB)
# PHOTOS_BACKUP_MAX_SOURCE_GB=50

# --- Convex database exports (separate bucket) ---
#   1. Create private bucket: hoa-convex-backups
#   2. Create Application Key scoped to hoa-convex-backups (Read and Write)
#   3. rclone config create hoa-b2-convex b2 account="$B2_CONVEX_ACCOUNT_ID" key="$B2_CONVEX_APPLICATION_KEY" hard_delete=false
# Uploaded nightly by scripts/backup-convex.sh; B2 retention default 30 days.

B2_CONVEX_BUCKET=hoa-convex-backups
B2_CONVEX_ACCOUNT_ID=
B2_CONVEX_APPLICATION_KEY=
RCLONE_CONVEX_REMOTE=hoa-b2-convex
CONVEX_B2_RETENTION_DAYS=30
